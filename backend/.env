# FoodZap Backend Environment Variables

# Server
PORT=5000
NODE_ENV=development

# MySQL Database Configuration
# Option 1: Individual variables (current)
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=ansh@2007
# DB_NAME=foodzap

# Option 2: Connection URL format (alternative)
DATABASE_URL=mysql://root:ansh@2007@localhost:3306/foodzap






# JWT Secret (generate a random string)
JWT_SECRET=foodzap_secret_key_change_this_in_production_2024
JWT_EXPIRE=7d

# Google Gemini AI API (get from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=AIzaSyCeQriRuruLvRgPanhL_cG6Ka5V-A3zEGM

# Google Maps API (get from https://console.cloud.google.com/)
# 1. Create project at Google Cloud Console
# 2. Enable APIs: Geocoding, Places, Maps JavaScript, Directions, Distance Matrix
# 3. Create API Key at: APIs & Services → Credentials
# 4. Replace below with your actual key (starts with AIzaSy...)
GOOGLE_MAPS_API_KEY=AIzaSyBkWF4sx2W3bQ1cFddLXTbHMaDLsPR4jEs

# Razorpay Payment Gateway (get from https://dashboard.razorpay.com/)
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_key_secret_here

# Google OAuth (get from https://console.cloud.google.com/)
# Steps:
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add Authorized JavaScript origins: http://localhost:3000
# 4. Add Authorized redirect URIs: http://localhost:5000/api/auth/google/callback
# 5. Copy Client ID and Secret below
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback



# Cloudinary for image uploads (get from https://cloudinary.com/)
